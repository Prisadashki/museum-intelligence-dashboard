{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://collectionapi.metmuseum.org/public/collection/v1/:path*"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ]
}
